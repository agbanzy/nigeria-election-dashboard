# Every consumed var is declared in app/config.py (strict by design).
# export these (or use direnv) — the app reads os.environ directly, no .env loader.

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/elections
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=*

# INEC IReV. IREV_API_KEY unset = INEC's public Angular SPA client key
# (baked into their bundle — not a secret). Override only if INEC rotates it.
IREV_API_BASE=https://dolphin-app-sleqh.ondigitalocean.app/api/v1
# IREV_API_KEY=

# Scraper daemon
SCRAPER_ENABLED=true
SCRAPER_DEFAULT_STATE_ID=15
# Multiplier on per-tick API budgets; 1.0 = polite (~960 calls/day), 8.0+ may
# trip INEC rate limits.
SCRAPER_BURST_FACTOR=1.0
# SCRAPER_INTERVAL_LIVE=120
# SCRAPER_INTERVAL_PREFLIGHT=300
# SCRAPER_INTERVAL_IDLE=86400
# SCRAPER_PREFLIGHT_WINDOW_HOURS=6

# Admin write endpoints (manual entry / OCR / bulk import) — X-Admin-Token header.
ADMIN_TOKEN=change-me

# Dashboard login users, consumed by `python -m app.seed_users`.
# JSON array of {email, name, role, password_hash}; password_hash is bcrypt:
#   python -c "import bcrypt, getpass; print(bcrypt.hashpw(getpass.getpass().encode(), bcrypt.gensalt()).decode())"
# SEED_USERS=[{"email":"you@example.com","name":"You","role":"admin","password_hash":"$2b$12$..."}]
