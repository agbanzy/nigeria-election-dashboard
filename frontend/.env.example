# Public base URL the browser uses for the Flask API ("" = same-origin routing).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Server-side URL for NextAuth's credentials provider + the admin proxy
# (in production this is the internal service-to-service address).
API_URL=http://localhost:8080

NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Must match the backend's ADMIN_TOKEN — injected server-side by the
# /admin-api proxy after verifying the NextAuth admin session.
ADMIN_TOKEN=

# Optional override for the live SSE endpoint.
# NEXT_PUBLIC_SSE_URL=
